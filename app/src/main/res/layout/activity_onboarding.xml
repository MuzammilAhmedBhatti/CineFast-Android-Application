<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000">

    <!-- ===== Background Poster Layer ===== -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Rotated Poster Grid -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:rotation="-20"
            android:scaleX="2.1"
            android:scaleY="2.1">

            <!-- Row Maker -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView style="@style/posterStyle" android:src="@drawable/m1"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m2"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m3"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView style="@style/posterStyle" android:src="@drawable/m4"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m5"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m6"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView style="@style/posterStyle" android:src="@drawable/m7"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m8"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m9"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView style="@style/posterStyle" android:src="@drawable/m4"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m5"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m6"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView style="@style/posterStyle" android:src="@drawable/m6"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m1"/>
                <ImageView style="@style/posterStyle" android:src="@drawable/m3"/>
            </LinearLayout>

        </LinearLayout>

        <!-- Overlay -->
        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#B3000000"/>

    </FrameLayout>

    <!-- ===== Text Section ===== -->
    <LinearLayout
        android:id="@+id/infoBox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp"
        app:layout_constraintBottom_toTopOf="@id/btnStart"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Explore now\nto experience the benefits"
            android:textColor="#FFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textAlignment="center"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Where every frame tells a story—your ticket to endless cinematic adventure."
            android:textColor="#DDDDDD"
            android:textAlignment="center"
            android:layout_marginTop="8dp"/>
    </LinearLayout>

    <!-- ===== Start Button ===== -->
    <Button
        android:id="@+id/btnStart"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:text="Get Started"
        android:textColor="#FFF"
        android:textStyle="bold"
        android:backgroundTint="#FF0000"
        android:layout_margin="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
