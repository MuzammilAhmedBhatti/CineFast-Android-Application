<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Header Container (35% of screen) -->
    <LinearLayout
        android:id="@+id/headerContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:padding="16dp"
        app:layout_constraintHeight_percent="0.35"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Status Bar & Back Button Row -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">


            <ImageButton
                android:id="@+id/backBtn"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:background="#80FFFFFF"
                android:src="@drawable/ic_back"
                android:scaleType="centerInside"
                android:padding="10dp"
                android:contentDescription="Back" />

            <!-- Status bar icons placeholders (signal, wifi, battery) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Time display (optional) -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="22:41"
                    android:textColor="#4D4D4D"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_marginEnd="8dp"/>
            </LinearLayout>
        </RelativeLayout>

        <!-- Movie Info Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_movie_card"
            android:orientation="vertical"
            android:padding="16dp"
            android:layout_gravity="center"
            android:gravity="center">

            <!-- Movie Title -->
            <TextView
                android:id="@+id/movieTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Oppenheimer"
                android:textColor="#000000"
                android:textSize="20sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <!-- Badges Row -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="12dp">

                <!-- UA Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" UA "
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_green"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="4dp"/>

                <!-- EN Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="EN"
                    android:textColor="#FFFFFF"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_gray"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginEnd="4dp"/>

                <!-- ScreenX Badge -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" ScreenX "
                    android:textColor="#000000"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:background="@drawable/bg_badge_gray"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"/>
            </LinearLayout>

            <!-- Theater Info -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Theater"
                android:textColor="#808080"
                android:textSize="10sp"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Store (DC Mall)"
                android:textColor="#000000"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"/>

            <!-- Info Row (List, Hall, Date, Time) -->
            <LinearLayout
                android:id="@+id/infoRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="4">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="List" 
                        android:textColor="#808080" 
                        android:textSize="10sp"/>
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="1st" 
                        android:textColor="#000000" 
                        android:textSize="11sp" 
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Hall" 
                        android:textColor="#808080" 
                        android:textSize="10sp"/>
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="1st"
                        android:textColor="#000000" 
                        android:textSize="11sp" 
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Date" 
                        android:textColor="#808080" 
                        android:textSize="10sp"/>
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content"
                        android:text="13.04.2025" 
                        android:textColor="#000000" 
                        android:textSize="11sp" 
                        android:textStyle="bold"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center">
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="Time" 
                        android:textColor="#808080" 
                        android:textSize="10sp"/>
                    <TextView 
                        android:layout_width="wrap_content" 
                        android:layout_height="wrap_content" 
                        android:text="22:15" 
                        android:textColor="#000000" 
                        android:textSize="11sp" 
                        android:textStyle="bold"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- Gradient Separator Line -->
    <View
        android:id="@+id/gradientSeparator"
        android:layout_width="0dp"
        android:layout_height="2dp"
        android:layout_marginHorizontal="40dp"
        android:background="#00C896"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerContainer" />

    <!-- Screen Curve (Below gradient line) -->
    <ImageView
        android:id="@+id/screenCurve"
        android:layout_width="0dp"
        android:layout_height="30dp"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="32dp"
        android:src="@drawable/ic_screen_curve"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/gradientSeparator" />

    <ImageView
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="260dp"
        android:adjustViewBounds="true"
        android:scaleType="fitXY"
        android:src="@drawable/gradient"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Seats Container -->
    <GridLayout
        android:id="@+id/seatContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:columnCount="9"
        android:rowCount="8"
        android:useDefaultMargins="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/screenCurve">

        <!-- Row 1 (3+3 seats) -->
        <Space android:layout_width="32dp" android:layout_height="32dp" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <!-- Row 2 (4+4 seats) -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <!-- Row 3 (4+4 seats) -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_selected" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_selected" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <!-- Row 4 (4+4 seats) -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <!-- Row 5 (4+4 seats) -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <!-- Row 6 (4+4 seats) -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_booked" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <!-- Row 7 (4+4 seats) -->
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_booked" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_booked" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <!-- Row 8 (3+3 seats) -->
        <Space android:layout_width="32dp" android:layout_height="32dp" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />

        <Space android:layout_width="32dp" android:layout_height="32dp" />

        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <View android:layout_width="32dp" android:layout_height="32dp" android:layout_margin="4dp" android:background="@drawable/bg_seat_available" />
        <Space android:layout_width="32dp" android:layout_height="32dp" />
    </GridLayout>

    <!-- Legend -->
    <LinearLayout
        android:id="@+id/legend"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="24dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/seatContainer">

    </LinearLayout>

    <!-- Selection Info -->
    <TextView
        android:id="@+id/selectionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Selected: 0 | Total: $0"
        android:textColor="@color/white"
        android:textSize="14sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/legend" />



    <!-- Bottom Buttons -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/bookBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Book Seats"
            android:textColor="@color/white"
            android:background="@drawable/bg_button_red"
            android:layout_marginEnd="8dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/proceedBtn"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Proceed to Snacks"
            android:textColor="@color/black"
            android:background="@drawable/bg_button_white"
            android:enabled="false"
            android:alpha="0.5"
            android:layout_marginStart="8dp"/>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
